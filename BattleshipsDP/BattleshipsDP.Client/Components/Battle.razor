@page "/battle"

@using SharedLibrary
@inject NavigationManager Navigation

<h3>Battle</h3>

<div class="tables-container">
    <div class="table-wrapper">
        <h4>Team Table</h4>
        <div class="grid-container">
            <!-- Column Headers -->
            <div class="grid-header"></div> <!-- Empty top-left corner -->
            @for (char col = 'A'; col < 'A' + teamBoard.Size; col++)
            {
                <div class="grid-header">@col</div>
            }

            @for (int row = 0; row < teamBoard.Size; row++)
            {
                <!-- Row Header -->
                <div class="grid-header">@row</div>
                @for (int col = 0; col < teamBoard.Size; col++)
                {
                    <div class="grid-item">@teamBoard.Grid[row][col].GetDescription()</div>
                }
            }
        </div>
    </div>

    <div class="fire-button-wrapper">
        <button class="fire-button" @onclick="Fire">Fire</button>
    </div>

    <div class="table-wrapper">
        <h4>Enemy Table</h4>
        <div class="grid-container">
            <!-- Column Headers -->
            <div class="grid-header"></div> <!-- Empty top-left corner -->
            @for (char col = 'A'; col < 'A' + enemyBoard.Size; col++)
            {
                <div class="grid-header">@col</div>
            }

            @for (int row = 0; row < enemyBoard.Size; row++)
            {
                <!-- Row Header -->
                <div class="grid-header">@row</div>
                @for (int col = 0; col < enemyBoard.Size; col++)
                {
                    <div class="grid-item" @onclick="() => SelectTarget(row, col)">
                        @enemyBoard.Grid[row][col].GetDescription()
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
    .tables-container {
        display: flex;
        justify-content: space-around;
        align-items: center;
        margin: auto;
        max-width: 1200px;
        gap: 30px;
    }

    .table-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .grid-container {
        display: grid;
        grid-template-columns: repeat(11, 1fr);
        gap: 1px;
        width: 100%;
        max-width: 420px;
    }

    .grid-header {
        background-color: #d0d0d0;
        border: 1px solid #ccc;
        text-align: center;
        padding: 15px;
        font-size: 12px;
        font-weight: bold;
    }

    .grid-item {
        background-color: #f0f0f0;
        border: 1px solid #ccc;
        text-align: center;
        padding: 15px;
        font-size: 12px;
        cursor: pointer;
    }

        .grid-item.selected {
            background-color: #ffcccb; /* Light red color for selected tile */
        }

    .fire-button-wrapper {
        display: flex;
        align-items: center;
    }

    .fire-button {
        padding: 10px 20px;
        font-size: 16px;
        cursor: pointer;
    }
</style>

@code {
    private Board teamBoard = new Board();
    private Board enemyBoard = new Board();
    private int selectedRow = -1;
    private int selectedCol = -1;

    [CascadingParameter]
    public HubConnection? HubConnection { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HubConnection is null)
        {
            Console.WriteLine("HubConnection is null in Battle.razor");
            return;
        }

        HubConnection.On<Board, Board>("UpdateBoards", (aTeamBoard, bTeamBoard) =>
        {
            Console.WriteLine("UpdateBoards event received");
            teamBoard = aTeamBoard;
            enemyBoard = bTeamBoard;

            // Log the received board details
            Console.WriteLine("Received ATeamBoard:");
            LogBoard(teamBoard);
            Console.WriteLine("Received BTeamBoard:");
            LogBoard(enemyBoard);

            StateHasChanged();
        });

        await HubConnection.StartAsync();
        Console.WriteLine("HubConnection started in Battle.razor");
    }

    private void LogBoard(Board board)
    {
        for (int row = 0; row < board.Size; row++)
        {
            for (int col = 0; col < board.Size; col++)
            {
                Console.Write($"{board.Grid[row][col].GetDescription()} ");
            }
            Console.WriteLine();
        }
    }

    private void SelectTarget(int row, int col)
    {
        selectedRow = row;
        selectedCol = col;
        Console.WriteLine($"Target selected at ({row}, {col})");
        StateHasChanged();
    }

    private async Task Fire()
    {
        if (selectedRow == -1 || selectedCol == -1)
        {
            Console.WriteLine("No target selected");
            return;
        }

        if (HubConnection is null)
        {
            Console.WriteLine("HubConnection is null in Fire method");
            return;
        }

        Console.WriteLine($"Fired at ({selectedRow}, {selectedCol})");

        await HubConnection.InvokeAsync("Fire", selectedRow, selectedCol);

        // Reset the selected target
        selectedRow = -1;
        selectedCol = -1;
        StateHasChanged();
    }

    private string GetGridItemClass(int row, int col)
    {
        return row == selectedRow && col == selectedCol ? "grid-item selected" : "grid-item";
    }
}
